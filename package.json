{
  "name": "wcygan-net",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "preview-static": "bunx serve .output/public",
    "deploy": "bun run build && bunx wrangler deploy",
    "test": "vitest run",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "pre-commit": "prettier --write . && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@tanstack/react-router-devtools": "^1.166.13",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.5",
    "nitro": "^3.0.260311-beta",
    "prettier": "3.8.3",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@shikijs/rehype": "^4.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-router": "^1.168.18",
    "@tanstack/react-start": "^1.167.32",
    "autoprefixer": "^10.4.27",
    "mermaid": "^11.14.0",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "shiki": "^4.0.2",
    "shiki-transformer-copy-button": "^0.0.6",
    "tailwindcss": "^3"
  }
}
